# ── docker-compose.dev.yml environment ────────────────────────────────────
# Copy this file to .env.dev on the VPS and fill in all values.
# NEVER commit .env.dev to git.

# Docker Hub username (must match DOCKERHUB_USERNAME GitHub secret)
DOCKERHUB_USERNAME=your-dockerhub-username

# VPS IP address or dev subdomain (no http://, no trailing slash)
# Examples:  123.456.789.0   or   dev.yourdomain.com
DEV_HOST=your-vps-ip-or-hostname

# JWT — must be at least 64 characters, random, and secret
JWT_SECRET=change-me-use-a-long-random-string-of-at-least-64-characters-here
JWT_EXPIRATION=7200000
