# ── docker-compose.production.yml environment ──────────────────────────────
# Copy this file to .env on the VPS and fill in all values.
# NEVER commit the .env file to git.

# Docker Hub username (must match DOCKERHUB_USERNAME secret in GitHub)
DOCKERHUB_USERNAME=your-dockerhub-username

# Your domain pointed at this VPS (no https://, no trailing slash)
DOMAIN=yourdomain.com

# Email used by Let's Encrypt for certificate expiry notifications
ACME_EMAIL=you@example.com

# Database
DATABASE_USERNAME=planningpoker
DATABASE_PASSWORD=change-me-use-a-strong-random-password

# JWT — must be at least 64 characters, random, and secret
JWT_SECRET=change-me-use-a-long-random-string-of-at-least-64-characters-here
JWT_EXPIRATION=7200000
